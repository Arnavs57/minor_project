# -----------------------------------------------------------------------------
# YOLO-style dataset configuration (dataset.yaml)
# -----------------------------------------------------------------------------
# This file describes where images and labels live and how many classes you have.
# Use it with Ultralytics YOLOv8 and with this project's training/yolo_dataset.py.
#
# Copy to dataset/data.yaml and set 'path' and split paths to match your layout.
# See docs/DATASET_FORMAT.md for full format and directory layout.
# -----------------------------------------------------------------------------

# Dataset root directory (absolute path or relative to this yaml file).
# If this file is dataset/data.yaml, use path: . so root = dataset/.
# All paths below (train, val, test) are relative to 'path' unless absolute.
path: .

# -----------------------------------------------------------------------------
# Splits: where to find images for train / val / test
# -----------------------------------------------------------------------------
# Each can be either:
#   - A directory path: all images inside that directory are used.
#   - A .txt file: each line is one image path (absolute or relative to 'path').
#
# Example with directories (layout A):
#   path: dataset
#   train: images/train
#   val:   images/val
#   test:  images/test
#
# Example with list files (layout B):
#   path: dataset
#   train: splits/train.txt
#   val:   splits/val.txt
#   test:   splits/test.txt
# -----------------------------------------------------------------------------
train: images/train
val:   images/val
test:  images/test

# -----------------------------------------------------------------------------
# Classes
# -----------------------------------------------------------------------------
# nc: number of classes (must match length of 'names').
# names: list of class names. Index in this list = class_id in annotation files.
nc: 5
names:
  - plastic_bottle
  - plastic_bag
  - fishing_net
  - can
  - other_waste

# Alternative: names as a dict (class_id -> name). Ultralytics accepts both.
# names:
#   0: plastic_bottle
#   1: plastic_bag
#   2: fishing_net
#   3: can
#   4: other_waste
